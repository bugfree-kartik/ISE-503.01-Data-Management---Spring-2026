# Backend — used locally. Copy this to .env and fill in your values.
# For production (Render), set DATABASE_URL instead of DB_* variables.

# Local PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sbu_dining
DB_USER=postgres
DB_PASSWORD=

# Production PostgreSQL (Neon / Render / Railway)
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

PORT=3001
